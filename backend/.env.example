# 🦊 BotMaRe - Configuración del Motor (Backend)

# ── SISTEMA Y RED ──────────────────────────────────────────────
PORT=3001
DASHBOARD_URL=http://localhost:3000
NODE_ENV=production
LOGGER_LEVEL=error

# ── MARCA BLANCA (Opcional) ───────────────────────────────────
# Cambia el nombre que aparece en el Dashboard y mensajes del sistema
NEXT_PUBLIC_APP_NAME="BotMaRe AI"

# ── PROVEEDORES DE IA (Mínimo 1 requerido) ─────────────────────
# Puedes poner múltiples llaves separadas por comas para rotación automática
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
NVIDIA_API_KEY=
OPENROUTER_API_KEY=

# Modelos por defecto (opcional cambiarlos)
GEMINI_MODEL=gemini-1.5-flash
OPENAI_MODEL=gpt-4o-mini
NVIDIA_MODEL=deepseek-ai/deepseek-v4-pro

# ── TELEGRAM (Respaldo y Control) ──────────────────────────────
# Obtén tu token con @BotFather
TELEGRAM_BOT_TOKEN=
# Tu ID numérico (obténlo con @userinfobot)
TELEGRAM_ALLOWED_USER_IDS=

# ── SEGURIDAD DEL DASHBOARD ────────────────────────────────────
# Credenciales para acceder a la interfaz web
DASHBOARD_USER=admin
DASHBOARD_PASS=admin123
