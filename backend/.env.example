# ============================================================
#  BotMaRe - Backend Environment Variables
#  Copia este archivo como ".env" y rellena los valores reales
#  cp .env.example .env
# ============================================================

# Puerto en el que corre el servidor backend
PORT=3001

# ── Inteligencia Artificial ──────────────────────────────────
# API Key de OpenAI (GPT-4, GPT-3.5, etc.)
# Obtén la tuya en: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...tu_clave_aqui...

# (Opcional) Si usas DeepSeek vía NVIDIA API
# DEEPSEEK_API_KEY=nvapi-...tu_clave_aqui...
# DEEPSEEK_BASE_URL=https://integrate.api.nvidia.com/v1

# ── Telegram Bot ─────────────────────────────────────────────
# Token del bot de Telegram
# Obtén uno hablando con @BotFather en Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIJKlmNoPQRsTUVwxyZ

# IDs de usuarios de Telegram que pueden usar el bot (separados por comas)
# Para obtener tu ID habla con @userinfobot en Telegram
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321
