# ============================================================
#  BotMaRe - Frontend Environment Variables
#  Copia este archivo como ".env" y rellena los valores reales
#  cp .env.example .env
# ============================================================

# ── Autenticación del Dashboard ──────────────────────────────
# Credenciales de acceso al panel de administración
# ¡IMPORTANTE! Cambia estas credenciales antes de usar en producción
DASHBOARD_USER="admin"
DASHBOARD_PASS="tu_password_seguro_aqui"

# ── URL del Backend ──────────────────────────────────────────
# (Opcional) URL del backend si no usas la config por defecto
# NEXT_PUBLIC_API_URL=http://localhost:3001
