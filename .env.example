# 🦊 BotMaRe AI - Plantilla de Configuración
# Copia este archivo como .env y rellena tus datos

# ── SISTEMA Y RED ──────────────────────────────────────────────
PORT=8000
DASHBOARD_URL=http://localhost:8000
NODE_ENV=production
LOGGER_LEVEL=error

# ── SEGURIDAD DEL DASHBOARD ────────────────────────────────────
# Usuario y contraseña para acceder a la interfaz web (localhost:8000)
DASHBOARD_USER=admin
DASHBOARD_PASS=tu_contrasena_segura

# ── MARCA BLANCA ──────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="BotMaRe AI"

# ── PROVEEDORES DE IA (Mínimo 1 requerido) ─────────────────────
# Rellena al menos una para que el bot pueda responder
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
NVIDIA_API_KEY=
OPENROUTER_API_KEY=

# Modelos recomendados
GEMINI_MODEL=gemini-1.5-flash
OPENAI_MODEL=gpt-4o-mini
NVIDIA_MODEL=deepseek-ai/deepseek-v4-pro

# ── TELEGRAM (Opcional) ───────────────────────────────────────
# Para control remoto y notificaciones de respaldo
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
